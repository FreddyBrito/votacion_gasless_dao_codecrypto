#!/usr/bin/env bash
#
# prepare-commit-msg hook
# Enforces Conventional Commits format.
#
# Format: <type>(<scope>): <description>
#
# Allowed types: feat, fix, docs, style, refactor, test, chore, perf, ci, revert
# Example:      feat(dao): add proposal creation endpoint

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits and amend
if [[ "$COMMIT_MSG" =~ ^Merge ]] || [[ "$COMMIT_MSG" =~ ^fixup! ]] || [[ "$COMMIT_MSG" =~ ^squash! ]]; then
  exit 0
fi

# Allowed types
TYPES="feat|fix|docs|style|refactor|test|chore|perf|ci|revert"

# Pattern: type(scope): description  OR  type: description
PATTERN="^(${TYPES})(\([a-z0-9 _-]+\))?: .+"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌  Invalid commit message format."
  echo ""
  echo "  Expected: <type>(<scope>): <description>"
  echo ""
  echo "  Types:    feat | fix | docs | style | refactor | test | chore | perf | ci | revert"
  echo "  Scopes:   dao, forwarder, frontend, relayer, config, scripts"
  echo ""
  echo "  Examples:"
  echo "    feat(dao): add proposal creation"
  echo "    fix(forwarder): validate signature before nonce increment"
  echo "    test(dao): add edge case for expired voting"
  echo "    chore: update foundry config"
  echo ""
  exit 1
fi
